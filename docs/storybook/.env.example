# For agents-ui, create a sandbox token server on cloud.livekit.io
# Used by most stories, since it works without a local LiveKit project.
VITE_PUBLIC_LK_SANDBOX_TOKEN_SERVER_ID=

# Used only by the AgentSessionView-01 story, which connects to a real local
# LiveKit project so it can be exercised against a real agent.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Explicit agent dispatch (https://docs.livekit.io/agents/server/agent-dispatch/#explicit)
# By default, an agent is automatically dispatched to each new room.
# Leave AGENT_NAME blank to enable automatic dispatch
AGENT_NAME=

# STORYBOOK
# https://storybook.js.org/docs/react/configure/telemetry#how-to-opt-out
STORYBOOK_DISABLE_TELEMETRY="1 pnpm storybook"
