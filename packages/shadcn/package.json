{
  "private": true,
  "name": "@livekit/agents-ui",
  "version": "1.0.7",
  "description": "",
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "build:deps": "pnpm --filter @livekit/agents-ui^... build",
    "pretest": "pnpm build:deps",
    "shadcn:build": "pnpm test && rm -rf dist && shadcn build --output ./dist/r && pnpm shadcn:doc-gen",
    "shadcn:serve": "pnpm shadcn:build && python3 -m http.server 3210 -d ./dist",
    "shadcn:doc-gen": "node --experimental-strip-types --env-file=.env.local ./scripts/doc-gen.ts",
    "shadcn:deploy": "pnpm shadcn:build && node --experimental-strip-types --env-file=.env.local ./scripts/update.ts",
    "shadcn:publish:agent-starter-react": "node --experimental-strip-types ./scripts/publish-agent-starter-react.ts",
    "shadcn:publish:livekit-web": "node --experimental-strip-types ./scripts/publish-livekit-web.ts",
    "shadcn:publish:all": "node --experimental-strip-types ./scripts/publish-downstream.ts",
    "shadcn:update": "pnpm dlx shadcn@latest add alert button button-group select separator sonner toggle tooltip message-scroller message bubble && pnpm format",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest --coverage",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "keywords": [],
  "author": "",
  "license": "Apache-2.0",
  "peerDependencies": {
    "@livekit/components-react": "workspace:*",
    "livekit-client": "catalog:",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@livekit/protocol": "catalog:",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@shadcn/react": "^0.2.1",
    "ai": "^5.0.105",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jose": "^6.0.12",
    "livekit-server-sdk": "^2.13.2",
    "lucide-react": "^1.0.0",
    "motion": "^12.16.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.2",
    "sonner": "^2.0.7",
    "streamdown": "^2.3.0",
    "tailwind-merge": "^3.3.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^24.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "eslint": "catalog:",
    "eslint-config-lk-custom": "workspace:*",
    "eslint-config-next": "^16.0.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.5.0",
    "jsdom": "^29.0.0",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "react-docgen-typescript": "^2.4.0",
    "shadcn": "^4.13.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite": "^8.0.0",
    "vitest": "^4.1.8"
  }
}
